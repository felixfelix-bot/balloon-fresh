  "pinout_ascii": "        ┌──────────────────────┐\n  3V3 ──┤                      ├── 5V\n  GND ──┤                      ├── GND\n  D0  0 ├── GPIO0              ├── 21  D10\n  D1  1 ├── GPIO1              ├── 20  D9\n  D2  2 ├── GPIO2              ├── 9   D8\n  D3  3 ├── GPIO3              ├── 8   D7\n  D4  4 ├── GPIO4              ├── 7   D6\n  D5  5 ├── GPIO5              ├── 6   RX\n  TX    ├──                    ├──     NC\n        ├──  [USB-C]  [U.FL]   ├──     BOOT\n        └──────────────────────┘",
  "spi_notes": {
    "SPI0": "Internal, connected to onboard flash (GPIO11-17 on ESP32-C3 chip, not broken out)",
    "SPI1": "Internal, connected to onboard flash",
    "SPI2": "User-accessible via GPIO matrix. ANY GPIO can be mapped to SPI2 signals (SCK, MISO, MOSI, CS) using gpio_matrix_out/gpio_matrix_in.",
    "GPIO4_7_JTAG": "GPIO4-7 are labeled 'JTAG' on silkscreen but are fully usable as general-purpose GPIO or SPI2 when JTAG is not enabled. They are NOT reserved for flash."
  },
  "firmware_gpio_map": {
    "SPI_SCK":  { "gpio": 6, "pin": "D6", "to": "LoRa2021 Pin 5 (SCK)" },
    "SPI_MISO": { "gpio": 2, "pin": "D2", "to": "LoRa2021 Pin 3 (MISO)" },
    "SPI_MOSI": { "gpio": 7, "pin": "D7", "to": "LoRa2021 Pin 4 (MOSI)" },
    "SPI_CS":   { "gpio": 10, "pin": "D10", "to": "LoRa2021 Pin 6 (NSS)" },
    "BUSY":     { "gpio": 4, "pin": "D4", "to": "LoRa2021 Pin 7 (BUSY)" },
    "RST":      { "gpio": 3, "pin": "D3", "to": "LoRa2021 Pin 14 (RST)" },
    "DIO9_IRQ": { "gpio": 5, "pin": "D5", "to": "LoRa2021 Pin 15 (DIO9)" },
    "I2C_SDA":  { "gpio": 8, "pin": "D8", "to": "BMP280 SDA (shared with onboard LED)" },
    "I2C_SCL":  { "gpio": 9, "pin": "D9", "to": "BMP280 SCL (shared with BOOT button)" },
    "LED":      { "gpio": 8, "pin": "D8", "to": "Onboard blue LED (inverted, shared with I2C SDA)" },
    "UART_TX":  { "gpio": 21, "pin": "D10", "to": "USB console TX" },
    "UART_RX":  { "gpio": 20, "pin": "D9", "to": "USB console RX" }
  },
  "caveats": [
    "GPIO4-7 for SPI+control means no JTAG debugging; use UART/printf only",
    "GPIO8 (I2C SDA) is shared with onboard LED: LED will flicker during I2C traffic (cosmetic only)",
    "GPIO9 (I2C SCL) is shared with BOOT button: has internal pullup (good for I2C), must be HIGH at boot",
    "GPIO2 (SPI MISO) is a strapping pin: must be floating or HIGH at boot for SPI boot mode (safe as input)",
    "Using GPIO6/7 for SPI: these are labeled JTAG on silkscreen but are general-purpose GPIO when JTAG not enabled",
    "U.FL antenna connector is in addition to onboard PCB antenna; some boards require solder bridge to switch",
    "ME6211 regulator needs >=4.3V on 5V pin for stable 3.3V output; direct 3.3V via 3V3 pin bypasses regulator"
  ],
