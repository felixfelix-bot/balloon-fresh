  ;; ========== LEARNINGS TEXT NOTES ==========
  (text "SPI LAYOUT: 20MHz continuous SCK proven. Traces <30mm, length-matched ~5mm. Ground plane under SPI bus."
    (at 170.18 20.32 0)
    (effects (font (size 1.27 1.27)) (justify left))
    (uuid "text-0002")
  )
  (text "STRAPPING PINS: GPIO8=HIGH at boot (download mode if pulled low). GPIO9=LOW at boot (download mode). Do NOT use for I2C with pullups on flight board — use GPIO20/GPIO21 instead."
    (at 170.18 30.48 0)
    (effects (font (size 1.27 1.27)) (justify left))
    (uuid "text-0003")
  )
  (text "RADIOLIB: Set radio.irqDioNum=9 before begin(). Pass tcxoVoltage=0 (LR2021 uses XTAL, not TCXO)."
    (at 170.18 40.64 0)
    (effects (font (size 1.27 1.27)) (justify left))
    (uuid "text-0004")
  )
  (text "POWER CHAIN: Solar→BAT54→1.0F supercap→TPS7A02→3.3V. SB3 selects USB vs solar power."
    (at 170.18 50.8 0)
    (effects (font (size 1.27 1.27)) (justify left))
    (uuid "text-0005")
  )
