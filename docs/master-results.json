  "bugs_fixed": [
    {
      "id": "CR_ENCODING",
      "commit": "b32f50b",
      "symptom": "SF9 and SF12 RX received 0 packets",
      "root_cause": "LORA_CR=5 invalid (range 1-4). SPI encoded (5<<4)=0x50.",
      "fix": "LORA_CR 5→1 (cr=4/5)"
    },
    {
      "id": "RSSI_SNR_SWAP",
      "commit": "dca7a84",
      "symptom": "RSSI always -127 dBm, SNR implausible",
      "root_cause": "buf[2] and buf[3] swapped in GET_LORA_PACKET_STATUS response",
      "fix": "buf[2]=RSSI (-val/2), buf[3]=SNR (signed /4)"
    },
    {
      "id": "PER_STATS",
      "commit": "9352337",
      "symptom": "PER reported 78% when only 2/200 lost",
      "root_cause": "resetStats() zeroed received count but maxSeq kept climbing",
      "fix": "Added cumulativeRx field surviving resetStats()"
    }
  ]
